# 飞书配置
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx

# OpenAI 配置（本地 vLLM，仅支持 Qwen3.6-27B，禁止开启思考模式）
OPENAI_API_KEY=sk-OHxqX4JPuOdo5pt901E087A36bFc437c8d3e46Ee68864cD4
OPENAI_BASE_URL=http://localhost:3000/v1
OPENAI_MODEL=Qwen3.6-27B
OPENAI_CONTEXT_WINDOW=262144
OPENAI_TEMPERATURE=0.7

# 禁止使用 deepseek-v4-flash 或其他模型
# 禁止开启思考模式（enable_thinking/reasoning/thinking 均为 false）

# 飞书访问控制
# DM 策略: open (全部允许) / allowlist (仅允许列表中的 open_id)
FEISHU_DM_POLICY=open
# DM 允许列表（逗号分隔的 open_id，仅 FEISHU_DM_POLICY=allowlist 时生效）
FEISHU_DM_ALLOWLIST=
# 群聊策略: open (全部允许) / allowlist (仅允许列表中的 chat_id) / disabled (不响应任何群消息)
FEISHU_GROUP_POLICY=open
# 群聊允许列表（逗号分隔的 chat_id，仅 FEISHU_GROUP_POLICY=allowlist 时生效）
FEISHU_GROUP_ALLOWLIST=
# 群聊是否需要 @mention 才响应（true/false）
FEISHU_REQUIRE_MENTION=true

# Compact 配置
COMPACT_THRESHOLD=0.85
COMPACT_RECENT_RATIO=0.15

# 路径配置（Docker 容器内路径）
SESSIONS_DIR=/app/sessions
UPLOADS_DIR=/app/uploads
CHROMA_DB_DIR=/app/chroma_db
MINERU_PROCESS_DIR=/app/mineru_process
RESUME_ARCHIVE_DIR=/app/resume_archive

# MinerU PDF 解析
# MinerU VLM 服务地址（容器使用 network_mode: host）
MINERU_SERVER_URL=http://localhost:8003
# MinerU 模型名称（可为空，由服务端决定）
# MINERU_MODEL_NAME=

# 日志级别
LOG_LEVEL=INFO
